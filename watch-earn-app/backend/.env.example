# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed to call this API (CORS)
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/watchearn?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Reward economy config (defaults - can be overridden via admin panel/DB)
COINS_PER_AD_VIEW=10
COINS_PER_OFFER_BASE=50
COIN_TO_CASH_RATE=0.001
MIN_WITHDRAWAL_COINS=5000
DAILY_AD_VIEW_CAP=20
DAILY_GAME_EARN_CAP=200

# Ad network / offerwall postback secret (verify incoming server callbacks)
AD_NETWORK_POSTBACK_SECRET=replace_with_secret_from_ad_network
OFFERWALL_POSTBACK_SECRET=replace_with_secret_from_offerwall_provider

# Optional but recommended once you have real provider accounts: comma
# separated list of the exact IPs your ad network / offerwall send
# postbacks from. Leave blank during local dev/testing.
AD_NETWORK_ALLOWED_IPS=
OFFERWALL_ALLOWED_IPS=

# Offerwall iframe URL + your publisher id from the provider
OFFERWALL_BASE_URL=https://example-offerwall.com/wall
OFFERWALL_PUBLISHER_ID=YOUR_PUBLISHER_ID

# Admin
ADMIN_EMAIL=admin@example.com
